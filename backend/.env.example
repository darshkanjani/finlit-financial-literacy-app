# FinLit backend environment template
# Copy this file to .env and fill in your own local values.

ENV=dev
RETURN_RESET_TOKEN_IN_RESPONSE=false

DATABASE_URL=sqlite:///./finlit.db

JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRES_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

LLM_PROVIDER=openai
LLM_API_KEY=your-openai-api-key-here

# Optional: password reset email settings.
# Leave blank for local demos unless you want real reset emails.
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_USE_CREDENTIALS=true
